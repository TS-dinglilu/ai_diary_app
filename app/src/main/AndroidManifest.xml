<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 录音 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- 前台服务（持续录音） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <!-- 后台运行，避免被系统杀死 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- 网络（AI 分析 / 云端转写） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 读写录音文件 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <!-- POST_NOTIFICATIONS（Android 13+ 前台通知） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 接收充电状态变化 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- 定时精确闹钟（自启动守护）。USE_EXACT_ALARM 有 Play 审核风险，仅用 SCHEDULE_EXACT_ALARM -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- 安装 APK（应用内自动更新） -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".App"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AIDiaryApp"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ChatDetailActivity"
            android:exported="false" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <activity
            android:name=".RecordManagementActivity"
            android:exported="false" />

        <activity
            android:name=".LogActivity"
            android:exported="false" />

        <activity
            android:name=".ContentDetailActivity"
            android:exported="false" />

        <!-- FileProvider：用于分享/导出文件 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- 持续录音前台服务 -->
        <service
            android:name=".service.RecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone"
            android:stopWithTask="false" />

        <!-- 监听充电状态，触发转写与 AI 分析 -->
        <receiver
            android:name=".receiver.PowerConnectionReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <!-- 守护接收器：定时闹钟 + 系统广播触发，确保 Service 被杀后自启动 -->
        <receiver
            android:name=".service.KeepAliveReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.ailogapp.KEEP_ALIVE" />
            </intent-filter>
        </receiver>

        <!-- 每日定时检查接收器：每天晚上8点检查并触发转写和分析 -->
        <receiver
            android:name=".receiver.DailyCheckReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.ailogapp.DAILY_CHECK" />
            </intent-filter>
        </receiver>

        <!-- 定时录音接收器：按设定时间自动启停录音 -->
        <receiver android:name=".receiver.ScheduleRecordingReceiver" android:exported="false">
            <intent-filter>
                <action android:name="com.example.ailogapp.SCHEDULE_START_RECORDING" />
                <action android:name="com.example.ailogapp.SCHEDULE_STOP_RECORDING" />
            </intent-filter>
        </receiver>

        <!-- MediaPipe LLM 推理需要的 OpenCL 库（GPU 加速，可选） -->
        <uses-native-library android:name="libOpenCL.so" android:required="false" />
        <uses-native-library android:name="libOpenCL-car.so" android:required="false" />
        <uses-native-library android:name="libOpenCL-pixel.so" android:required="false" />

    </application>
</manifest>
