<?xml version="1.0" encoding="utf-8"?>
<!-- 微信风格聊天详情页 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- 顶部栏：48dp 高，白色背景 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="@android:color/transparent"
            android:contentDescription="@string/app_name"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/chat_default_title" />

        <!-- 占位 View，与返回按钮等宽以保持标题居中 -->
        <View
            android:layout_width="36dp"
            android:layout_height="36dp" />

    </LinearLayout>

    <!-- 底部 1dp 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- 消息列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_base"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <!-- 底部输入栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:padding="8dp">

        <!-- 语音按钮 -->
        <ImageButton
            android:id="@+id/btnVoice"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_mic"
            android:background="@drawable/bg_chat_input"
            android:contentDescription="@string/chat_voice"
            app:tint="@color/text_secondary"
            android:scaleType="centerInside"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:hint="@string/chat_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="14sp"
            android:maxLines="1"
            android:inputType="text"
            android:imeOptions="actionSend"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="@string/chat_send"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/wechat_green"
            app:cornerRadius="6dp"
            app:strokeWidth="0dp" />

    </LinearLayout>

</LinearLayout>
