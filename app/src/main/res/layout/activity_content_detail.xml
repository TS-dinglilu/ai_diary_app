<?xml version="1.0" encoding="utf-8"?>
<!-- 内容详情页：查看完整转写/分析结果 + 编写笔记 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- ===== 顶部栏 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="@android:color/transparent"
            android:contentDescription="@string/app_name"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="转写内容" />

        <View
            android:layout_width="36dp"
            android:layout_height="36dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ===== 内容区域（可滚动） ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="@color/bg_base">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 内容卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_surface"
                android:padding="20dp"
                android:layout_margin="12dp"
                android:elevation="1dp">

                <!-- 转写内容（type=transcript 时显示） -->
                <TextView
                    android:id="@+id/tvTranscriptContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="5dp"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="完整转写内容..." />

                <!-- 分析：情绪 -->
                <TextView
                    android:id="@+id/tvAnalysisEmotion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_record"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="情绪：开心 (0.8)" />

                <!-- 分析：摘要标题 -->
                <TextView
                    android:id="@+id/tvSummaryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/detail_summary"
                    android:textColor="@color/accent_action"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- 分析：摘要内容 -->
                <TextView
                    android:id="@+id/tvAnalysisSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="今天整体情绪积极..." />

                <!-- 分析：日记标题 -->
                <TextView
                    android:id="@+id/tvDiaryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/detail_diary"
                    android:textColor="@color/accent_action"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- 分析：日记内容 -->
                <TextView
                    android:id="@+id/tvAnalysisDiary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="5dp"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="今天是忙碌而充实的一天..." />
            </LinearLayout>

            <!-- ===== 已有笔记列表 ===== -->
            <LinearLayout
                android:id="@+id/layoutExistingNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="12dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/journal_note"
                    android:textColor="@color/accent_action"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/notesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- ===== 写笔记区域 ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_surface"
                android:padding="16dp"
                android:layout_margin="12dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/journal_note"
                    android:textColor="@color/accent_action"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNoteContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minLines="3"
                    android:gravity="top|start"
                    android:hint="@string/journal_note_hint"
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp"
                    android:background="@drawable/bg_note_input"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:importantForAutofill="no"
                    tools:text="笔记内容..." />

                <Button
                    android:id="@+id/btnSaveNote"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/journal_note_save"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/wechat_green" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
