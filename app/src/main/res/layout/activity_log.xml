<?xml version="1.0" encoding="utf-8"?>
<!-- 日志查看页面 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- ===== 顶部栏 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="@android:color/transparent"
            android:contentDescription="@string/app_name"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/me_log" />

        <ImageButton
            android:id="@+id/btnExport"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_export"
            android:background="@android:color/transparent"
            android:contentDescription="@string/log_export"
            app:tint="@color/text_primary" />

    </LinearLayout>

    <!-- 底部 1dp 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ===== 日志信息栏 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvLogInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            tools:text="今日日志 · 12.5 KB" />

        <Button
            android:id="@+id/btnClear"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/log_clear"
            android:textSize="12sp"
            android:textColor="@color/accent_record" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ===== 日志内容区域 ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_base">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvLogContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                tools:text="[2026-07-04 10:00:00] [INFO] [App] 应用启动\n[2026-07-04 10:00:01] [INFO] [RecordingService] 录音服务启动" />
        </HorizontalScrollView>
    </ScrollView>

</LinearLayout>
