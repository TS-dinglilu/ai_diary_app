<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base"
    android:paddingTop="24dp">

    <!-- 筛选区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:boxStrokeColor="@color/divider"
            app:boxBackgroundColor="@color/bg_surface"
            android:hint="@string/filter_all_dates">

            <AutoCompleteTextView
                android:id="@+id/spDateFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:inputType="none"
                android:padding="12dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            app:boxStrokeColor="@color/divider"
            app:boxBackgroundColor="@color/bg_surface"
            android:hint="@string/filter_all_status">

            <AutoCompleteTextView
                android:id="@+id/spStatusFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:inputType="none"
                android:padding="12dp" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- 全选 + 计数 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvSelectedCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/accent_action"
            android:textSize="12sp"
            android:text="@string/delete_selected_count" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectAllDate"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/select_all_date"
            android:textColor="@color/accent_action"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectAll"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/select_all"
            android:textColor="@color/accent_action"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 删除类型选择 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/delete_type_label"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupDeleteType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDeleteAudio"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/delete_type_audio"
                android:textSize="12sp"
                android:checked="true"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/bg_surface"
                app:chipStrokeColor="@color/accent_action"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDeleteTranscript"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/delete_type_transcript"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/bg_surface"
                app:chipStrokeColor="@color/accent_action"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDeleteBoth"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/delete_type_both"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/bg_surface"
                app:chipStrokeColor="@color/accent_action"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="true" />
        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="24dp"
        android:background="@color/divider" />

    <!-- 录音列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDeleteList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="48dp"
        android:text="@string/delete_empty"
        android:textColor="@color/text_tertiary"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:text="@string/delete_cancel"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmDelete"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="120dp"
            android:text="@string/delete_confirm"
            android:textColor="@color/bg_base"
            android:textSize="14sp"
            app:backgroundTint="@color/accent_record"
            app:cornerRadius="10dp" />
    </LinearLayout>
</LinearLayout>
