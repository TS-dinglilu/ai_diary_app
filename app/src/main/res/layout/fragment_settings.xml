<?xml version="1.0" encoding="utf-8"?>
<!-- 设置 Fragment 布局（嵌入底部导航，不需要顶部返回栏） -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== 录音控制 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <TextView
                style="@style/SectionLabel"
                android:text="@string/section_recording" />

            <View
                android:layout_width="24dp"
                android:layout_height="2dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp"
                android:background="@color/wechat_green" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_stopped"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="@color/text_primary"
                android:textSize="40sp"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/btn_start"
                android:textSize="15sp"
                android:textColor="@color/bg_surface"
                app:icon="@drawable/ic_mic"
                app:iconTint="@color/bg_surface"
                app:iconGravity="textStart"
                app:backgroundTint="@color/wechat_green"
                app:cornerRadius="12dp"
                app:strokeWidth="0dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="24dp"
            android:background="@color/divider" />

        <!-- ===== 处理操作 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <TextView
                style="@style/SectionLabel"
                android:text="@string/section_actions" />

            <View
                android:layout_width="24dp"
                android:layout_height="2dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:background="@color/accent_action" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTranscribe"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/btn_transcribe"
                    android:textSize="14sp"
                    android:textColor="@color/accent_action"
                    app:strokeColor="@color/accent_action"
                    app:strokeWidth="1dp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnalyze"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/btn_analyze"
                    android:textSize="14sp"
                    android:textColor="@color/accent_action"
                    app:strokeColor="@color/accent_action"
                    app:strokeWidth="1dp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="10dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetranscribeAll"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:text="@string/journal_retranscribe_all"
                android:textColor="@color/text_secondary"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp" />

            <TextView
                android:id="@+id/tvTaskStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                tools:text="处理中…"
                tools:visibility="visible"
                android:textColor="@color/accent_action"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="24dp"
            android:background="@color/divider" />

        <!-- ===== 配置 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <TextView
                style="@style/SectionLabel"
                android:text="@string/section_settings" />

            <View
                android:layout_width="24dp"
                android:layout_height="2dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:background="@color/text_tertiary" />

            <!-- 转写模式 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_transcribe_mode"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginBottom="12dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOff"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_off"
                    android:checked="true"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/bg_surface"
                    app:chipStrokeColor="@color/accent_action"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLocal"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_local"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/bg_surface"
                    app:chipStrokeColor="@color/accent_action"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWhisper"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_whisper"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/bg_surface"
                    app:chipStrokeColor="@color/accent_action"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAi"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_ai"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/bg_surface"
                    app:chipStrokeColor="@color/accent_action"
                    app:chipStrokeWidth="1dp" />
            </com.google.android.material.chip.ChipGroup>

            <!-- ASR 模型状态 + 下载按钮 + 进度条 -->
            <LinearLayout
                android:id="@+id/layoutAsrModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvAsrModelStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/asr_model_not_downloaded"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDownloadAsr"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/llm_download"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeleteAsr"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/model_delete"
                        android:textColor="@color/design_default_color_error"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressAsr"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    android:max="100" />
            </LinearLayout>

            <!-- 语音转文字模型下载链接（缩短，右侧无按钮，按钮在上方） -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:id="@+id/layoutAsrModelUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="@color/divider"
                app:boxBackgroundColor="@color/bg_surface"
                app:hintTextColor="@color/text_tertiary"
                android:hint="@string/hint_asr_model_url"
                app:helperText="@string/model_link_hint"
                app:helperTextEnabled="true">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAsrModelUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:inputType="textUri"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- AI 分析模式 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_analyze_mode"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupAnalyzeMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginBottom="12dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAnalyzeCloud"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_analyze_cloud"
                    android:checked="true"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/bg_surface"
                    app:chipStrokeColor="@color/accent_action"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAnalyzeLocal"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_analyze_local"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/bg_surface"
                    app:chipStrokeColor="@color/accent_action"
                    app:chipStrokeWidth="1dp" />
            </com.google.android.material.chip.ChipGroup>

            <!-- LLM 模型状态 + 下载按钮 + 进度条 -->
            <LinearLayout
                android:id="@+id/layoutLLMModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvLLMModelStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/llm_model_not_downloaded"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDownloadLLM"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/llm_download"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeleteLLM"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/model_delete"
                        android:textColor="@color/design_default_color_error"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressLLM"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    android:max="100" />

                <!-- 本地离线分析模型下载链接 -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxStrokeColor="@color/divider"
                    app:boxBackgroundColor="@color/bg_surface"
                    app:hintTextColor="@color/text_tertiary"
                    android:hint="@string/hint_llm_model_url"
                    app:helperText="@string/model_link_hint"
                    app:helperTextEnabled="true">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLlmModelUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_tertiary"
                        android:inputType="textUri"
                        android:textSize="13sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- 充电自动触发 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_auto_options"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"
                android:layout_marginTop="4dp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAutoTranscribe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/switch_auto_transcribe"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingVertical="8dp"
                android:checked="false" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAutoAnalyze"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/switch_auto_analyze"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingVertical="8dp"
                android:checked="true" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/divider" />

            <!-- 定时录音 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_schedule_recording"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchScheduleRecording"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/switch_schedule_recording"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingVertical="8dp"
                android:checked="false" />

            <LinearLayout
                android:id="@+id/layoutScheduleStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/schedule_start_time"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvScheduleStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/text_tertiary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutScheduleStop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/schedule_stop_time"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvScheduleStop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/text_tertiary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/divider" />

            <!-- 数据备份与恢复 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_backup"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/backup_data_desc"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <!-- WebDAV 配置 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_webdav_config"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:boxBackgroundColor="@color/bg_surface"
                app:boxStrokeColor="@color/wechat_green"
                app:hintTextColor="@color/wechat_green">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWebdavUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_webdav_url"
                    android:inputType="textUri"
                    android:textSize="13sp"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:boxBackgroundColor="@color/bg_surface"
                app:boxStrokeColor="@color/wechat_green"
                app:hintTextColor="@color/wechat_green">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWebdavEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_webdav_email"
                    android:inputType="textEmailAddress"
                    android:textSize="13sp"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:endIconMode="password_toggle"
                app:boxBackgroundColor="@color/bg_surface"
                app:boxStrokeColor="@color/wechat_green"
                app:hintTextColor="@color/wechat_green">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWebdavPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_webdav_password"
                    android:inputType="textPassword"
                    android:textSize="13sp"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 备份按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackupCloud"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_backup_cloud"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackupLocal"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_backup_local"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 恢复按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRestoreCloud"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_restore_cloud"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRestoreLocal"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_restore_local"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAutoBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/switch_auto_backup"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingVertical="8dp"
                android:checked="false" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAutoBackupOnStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/switch_auto_backup_on_start"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingVertical="8dp"
                android:checked="true" />

            <TextView
                android:id="@+id/tvBackupStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- 自动删除已转写旧录音 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_auto_delete"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"
                android:layout_marginTop="4dp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAutoDelete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/switch_auto_delete"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingVertical="8dp"
                android:checked="false" />

            <LinearLayout
                android:id="@+id/layoutAutoDeleteDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_auto_delete_days"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    app:boxStrokeColor="@color/divider"
                    app:boxBackgroundColor="@color/bg_surface"
                    app:hintTextColor="@color/text_tertiary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAutoDeleteDays"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_tertiary"
                        android:inputType="number"
                        android:textSize="13sp"
                        android:gravity="center" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_days"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/divider" />

            <!-- 界面设置（移到 AI 接口之前） -->
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchDefaultCollapse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/switch_default_collapse"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingVertical="8dp"
                android:layout_marginBottom="8dp"
                android:checked="true" />

            <!-- 深色模式选择 -->
            <LinearLayout
                android:id="@+id/layoutThemeMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:layout_marginBottom="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/theme_mode"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvThemeMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/text_tertiary" />
            </LinearLayout>

            <!-- AI 接口配置 -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:boxStrokeColor="@color/divider"
                app:boxBackgroundColor="@color/bg_surface"
                app:hintTextColor="@color/text_tertiary"
                android:hint="@string/hint_api_url">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:inputType="textUri"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:boxStrokeColor="@color/divider"
                app:boxBackgroundColor="@color/bg_surface"
                app:hintTextColor="@color/text_tertiary"
                android:hint="@string/hint_api_key">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:inputType="textPassword"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:boxStrokeColor="@color/divider"
                app:boxBackgroundColor="@color/bg_surface"
                app:hintTextColor="@color/text_tertiary"
                android:hint="@string/hint_model">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:boxStrokeColor="@color/divider"
                app:boxBackgroundColor="@color/bg_surface"
                app:hintTextColor="@color/text_tertiary"
                android:hint="@string/hint_transcribe_url">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTranscribeUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:inputType="textUri"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="@color/divider"
                app:boxBackgroundColor="@color/bg_surface"
                app:hintTextColor="@color/text_tertiary"
                android:hint="@string/hint_transcribe_model">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTranscribeModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteRecords"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="10dp"
                android:text="@string/btn_delete_records"
                android:textColor="@color/accent_record"
                android:textSize="14sp"
                app:strokeColor="@color/accent_record"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveConfig"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/save_config"
                android:textColor="@color/bg_base"
                android:textSize="14sp"
                app:backgroundTint="@color/accent_action"
                app:cornerRadius="10dp"
                app:strokeWidth="0dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="24dp"
            android:background="@color/divider" />

    </LinearLayout>
</ScrollView>
