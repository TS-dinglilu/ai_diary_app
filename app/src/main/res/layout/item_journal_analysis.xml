<?xml version="1.0" encoding="utf-8"?>
<!-- AI 分析条目 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/journal_analysis"
            android:textColor="@color/accent_action"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/tvEmotion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_record"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"
            tools:text="开心 (0.8)" />

        <ImageButton
            android:id="@+id/btnExportAnalysis"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_export"
            android:contentDescription="@string/journal_export_analysis"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnDeleteAnalysis"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete_small"
            android:contentDescription="@string/journal_delete_analysis" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        tools:text="今天整体情绪积极，上午专注工作..." />

    <TextView
        android:id="@+id/tvDiary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:lineSpacingExtra="4dp"
        android:maxLines="6"
        android:ellipsize="end"
        tools:text="今天是忙碌而充实的一天..." />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/divider" />
</LinearLayout>
