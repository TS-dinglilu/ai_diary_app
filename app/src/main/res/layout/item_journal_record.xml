<?xml version="1.0" encoding="utf-8"?>
<!-- 录音条目：含录音信息 + 转写内容 + 删除按钮 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            tools:text="08:30 · 30:00 · 1.2MB" />

        <TextView
            android:id="@+id/tvSpeaker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/accent_action"
            android:textSize="11sp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_speaker_tag"
            android:visibility="gone"
            tools:text="说话人1"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvDeleted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/label_deleted"
            android:textColor="@color/accent_record"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            tools:text="已转写" />

        <TextView
            android:id="@+id/btnRetranscribe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/journal_retranscribe"
            android:textColor="@color/accent_action"
            android:textSize="11sp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:background="?android:attr/selectableItemBackground"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageButton
            android:id="@+id/btnPlayRecord"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_play"
            android:contentDescription="@string/journal_play_record" />

        <ImageButton
            android:id="@+id/btnExportRecord"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_export"
            android:contentDescription="@string/journal_export_record"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnDeleteRecord"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete_small"
            android:contentDescription="@string/journal_delete_record" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTranscript"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:maxLines="4"
        android:ellipsize="end"
        tools:text="转写内容预览，这是今天录音的转写文本..." />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/btnDeleteTranscript"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/journal_delete_transcript"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackground"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnExportTranscript"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/journal_export_transcript"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackground"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
